{
  "name": "Nocky GUI test",

  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "vscode",
      "installZsh": false,
      "configureZshAsDefaultShell": false,
      "upgradePackages": false
    },

    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "password": "vscode",
      "webPort": "6080"
    }
  },

  "forwardPorts": [6080],

  "portsAttributes": {
    "6080": {
      "label": "Nocky desktop",
      "onAutoForward": "notify",
      "visibility": "private"
    }
  },

  "runArgs": [
    "--shm-size=1g"
  ],

  "containerEnv": {
    "DISPLAY": ":1",
    "GDK_BACKEND": "x11",
    "GSK_RENDERER": "cairo",
    "LIBGL_ALWAYS_SOFTWARE": "1",
    "WEBKIT_DISABLE_COMPOSITING_MODE": "1"
  },

  "remoteUser": "vscode"
}
